        <mxCell id="zbLk2q1AzNFV4_ArqPZ1-199" value="&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(10, 10, 10); background-color: rgb(255, 255, 255);&quot;&gt;&lt;font style=&quot;font-weight: bold; font-size: 13px;&quot; face=&quot;Courier New&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Courier New&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-weight: 400; font-family: Helvetica; background-color: rgb(251, 251, 251);&quot;&gt;&lt;b style=&quot;font-family: &amp;quot;Courier New&amp;quot;; color: rgb(10, 10, 10); background-color: rgb(255, 255, 255);&quot;&gt;O(1)&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;:-&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-weight: 400; font-family: Garamond;&quot;&gt;Die Laufzeit (der Aufwand) &lt;/i&gt;&lt;i style=&quot;font-family: Garamond;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font color=&quot;#7f00ff&quot;&gt;&lt;u&gt;bleibt konstant&lt;/u&gt;&lt;/font&gt;&lt;/b&gt;&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-weight: 400; font-family: Garamond;&quot;&gt;, unabhängig von Anzahl der zu sortierenden Elemente.&lt;/i&gt;&lt;span style=&quot;color: rgb(10, 10, 10); font-weight: bold; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font style=&quot;font-weight: bold;&quot; face=&quot;Courier New&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;b style=&quot;color: rgb(10, 10, 10);&quot;&gt;O(n)&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;:-&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;font style=&quot;color: rgb(10, 10, 10);&quot; face=&quot;Garamond&quot;&gt;&lt;i style=&quot;&quot;&gt;Die&amp;nbsp;&lt;/i&gt;&lt;/font&gt;&lt;/span&gt;&lt;i style=&quot;color: rgb(10, 10, 10); background-color: rgb(255, 255, 255); font-family: Garamond;&quot;&gt;Laufzeit (der Aufwand)&lt;/i&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Garamond&quot;&gt;&lt;i style=&quot;&quot;&gt;&lt;font color=&quot;#0a0a0a&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;b style=&quot;&quot;&gt;&lt;font color=&quot;#0000cc&quot;&gt;&lt;u&gt;steigt linear&lt;/u&gt;&lt;/font&gt; &lt;/b&gt;&lt;font color=&quot;#0a0a0a&quot;&gt;mit der Anzahl der zu sortierenden Elemente.&lt;/font&gt;&lt;br&gt;&lt;/i&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;b style=&quot;font-family: &amp;quot;Courier New&amp;quot;; color: rgb(10, 10, 10); background-color: rgb(255, 255, 255);&quot;&gt;O(log(n))&amp;nbsp; :-&amp;nbsp;&lt;/b&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;Die&amp;nbsp;&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); background-color: rgb(255, 255, 255); font-family: Garamond;&quot;&gt;Laufzeit (der Aufwand)&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;&amp;nbsp;&lt;/i&gt;&lt;i style=&quot;font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;&quot; color=&quot;#00cc66&quot;&gt;&lt;u&gt;steigt logarithmisch&lt;/u&gt;&lt;/font&gt;&lt;/b&gt;&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt; zur Anzahl der zu sortierenden Elemente [also weniger stark als n]&lt;/i&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;font style=&quot;background-color: initial;&quot;&gt;&lt;b style=&quot;font-family: &amp;quot;Courier New&amp;quot;; color: rgb(10, 10, 10); background-color: rgb(255, 255, 255);&quot;&gt;O(n*log(n)):-&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;Die&amp;nbsp;&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); background-color: rgb(255, 255, 255); font-family: Garamond;&quot;&gt;Laufzeit (der Aufwand)&lt;/i&gt;&lt;i style=&quot;font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font color=&quot;#0a0a0a&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;&quot; color=&quot;#009900&quot;&gt;&lt;u&gt;steigt log-linear&lt;/u&gt;&lt;/font&gt;&lt;/b&gt;&lt;font color=&quot;#0a0a0a&quot;&gt; zur Anzahl der zu sortierenden Elemente [also etwas stärker als n]&lt;/font&gt;&lt;/i&gt;&lt;b style=&quot;font-family: &amp;quot;Courier New&amp;quot;; color: rgb(10, 10, 10); background-color: rgb(255, 255, 255);&quot;&gt;&amp;nbsp;&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;b style=&quot;font-family: &amp;quot;Courier New&amp;quot;; color: rgb(10, 10, 10); background-color: rgb(255, 255, 255);&quot;&gt;O(n&lt;sup&gt;2&lt;/sup&gt;)&amp;nbsp; &amp;nbsp; &amp;nbsp; :-&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;Die&amp;nbsp;&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); background-color: rgb(255, 255, 255); font-family: Garamond;&quot;&gt;Laufzeit (der Aufwand)&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;&amp;nbsp;&lt;/i&gt;&lt;i style=&quot;font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font color=&quot;#ff8000&quot;&gt;&lt;b&gt;&lt;u&gt;steigt quadratisch&lt;/u&gt;&lt;/b&gt;&lt;/font&gt;&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt; zur Anzahl der zu sortierenden Elemente&lt;/i&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;b style=&quot;font-family: &amp;quot;Courier New&amp;quot;; color: rgb(10, 10, 10); background-color: rgb(255, 255, 255);&quot;&gt;O(2&lt;sup&gt;n&lt;/sup&gt;)&amp;nbsp; &amp;nbsp; &amp;nbsp; :-&amp;nbsp;&lt;/b&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;Die&amp;nbsp;&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); background-color: rgb(255, 255, 255); font-family: Garamond;&quot;&gt;Laufzeit (der Aufwand)&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;&amp;nbsp;&lt;/i&gt;&lt;i style=&quot;font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font color=&quot;#ff0000&quot;&gt;&lt;b&gt;&lt;u&gt;steigt expontiell&lt;/u&gt;&lt;/b&gt;&lt;/font&gt;&lt;/i&gt;&lt;i style=&quot;color: rgb(10, 10, 10); font-family: Garamond; background-color: rgb(255, 255, 255);&quot;&gt; zur Anzahl der zu sortierenden Elemente&lt;/i&gt;&lt;b style=&quot;font-family: &amp;quot;Courier New&amp;quot;; color: rgb(10, 10, 10); background-color: rgb(255, 255, 255);&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;container=0;" parent="1" vertex="1">
